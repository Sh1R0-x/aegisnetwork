# ─── SMTP Configuration (OVH MX Plan) ────────────────────────────────────
# Mot de passe : celui de la boîte contact@aegisnetwork.fr (espace client OVH)
# NE JAMAIS commiter le mot de passe — le stocker en variable d'environnement uniquement.
SMTP_HOST=smtp.mail.ovh.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@aegisnetwork.fr
# SMTP_PASS=   ← à définir en variable d'environnement serveur, PAS dans ce fichier

# ─── Contact Email ────────────────────────────────────────────────────────
CONTACT_TO=contact@aegisnetwork.fr
CONTACT_FROM_NAME=AEGIS NETWORK
CONTACT_FROM_EMAIL=website@aegisnetwork.fr

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─── Frontend Production API (optionnel) ──────────────────────────────────
# Laisser vide pour un backend same-origin derrière /api/*
# Exemple : https://api.aegisnetwork.fr
VITE_CONTACT_API_BASE=
