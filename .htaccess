RewriteEngine On
Options -Indexes

# HSTS — force HTTPS for 1 year, includeSubDomains
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Canonical publique unique : HTTPS + non-www
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.aegisnetwork\.fr$ [NC]
RewriteRule ^ https://aegisnetwork.fr%{REQUEST_URI} [R=301,L]

# Éviter les doublons /index.html et /dist/*
RewriteCond %{THE_REQUEST} \s/+index\.html(?:[\s?]|$) [NC]
RewriteRule ^index\.html$ https://aegisnetwork.fr/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+(.+/)index\.html(?:[\s?]|$) [NC]
RewriteRule ^(?:dist/)?(.+)/index\.html$ https://aegisnetwork.fr/%1 [R=301,L]

RewriteCond %{THE_REQUEST} \s/+dist/index\.html(?:[\s?]|$) [NC]
RewriteRule ^dist/index\.html$ https://aegisnetwork.fr/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+dist/?(?:[\s?]|$) [NC]
RewriteRule ^dist/?$ https://aegisnetwork.fr/ [R=301,L]

RewriteCond %{THE_REQUEST} \s/+dist/(.+?)(?:[\s?]|$) [NC]
RewriteRule ^dist/(.+)$ https://aegisnetwork.fr/$1 [R=301,L]

# Servir depuis dist/
RewriteCond %{REQUEST_URI} !^/dist/
RewriteRule ^(.*)$ /dist/$1 [L]

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 0 seconds"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/plain "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
  ExpiresByType text/xml "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(?:html?|txt|xml)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(?:css|js|mjs|svg|webp|png|jpe?g|gif|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
